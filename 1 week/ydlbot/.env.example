# ===== Telegram =====
TELEGRAM_BOT_TOKEN=PUT_YOUR_TOKEN_HERE

# ===== LLM (чат) — alem.ai, OpenAI-совместимый =====
LLM_BASE_URL=https://llm.alem.ai/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=gemma4

# ===== Embeddings — alem.ai =====
EMBED_BASE_URL=https://llm.alem.ai/v1
EMBED_API_KEY=sk-xxxxxxxxxxxxxxxx
EMBED_MODEL=text-1024

# ===== Скрейпинг =====
SCRAPE_BASE_URL=https://yessenovfoundation.org/ru/
SCRAPE_MAX_PAGES=80
SCRAPE_DELAY=0.5

# ===== RAG =====
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=5
MIN_SCORE=0.25
